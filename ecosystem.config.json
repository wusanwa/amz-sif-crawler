{
  "apps": [
    {
      "name": "mcp-crawler-service",
      "script": "mcp_server.py",
      "args": "--mode sse --port 8000",
      "interpreter": "./.venv/bin/python",
      "env": {
        "PYTHONPATH": "."
      },
      "watch": false,
      "autorestart": true,
      "max_memory_restart": "1G",
      "log_date_format": "YYYY-MM-DD HH:mm Z"
    }
  ]
}
